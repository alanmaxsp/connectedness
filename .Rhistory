#!/usr/bin/env Rscript
# Regenerate package interfaces and docs from source comments.
# Run from repository root:
#   Rscript scripts/update_docs.R
if (!requireNamespace("Rcpp", quietly = TRUE)) {
stop("Package 'Rcpp' is required.")
}
if (!requireNamespace("devtools", quietly = TRUE)) {
stop("Package 'devtools' is required.")
}
Rcpp::compileAttributes()
devtools::document()
cat("\nDocumentation refresh complete.\n")
cat("Remember to commit:\n")
cat("  - NAMESPACE\n")
cat("  - man/*.Rd\n")
cat("  - R/RcppExports.R\n")
cat("  - src/RcppExports.cpp\n\n")
devtools::test()
usethis::use_testthat(3)
usethis::use_test("build_ginv")
usethis::use_testthat(3)
usethis::use_test("build_ainv")
usethis::use_test("build_ginv")
usethis::use_test("compute_connectedness")
test_that("build_Ainv devuelve Ainv sparse y F con dimensiones correctas", {
ped <- data.frame(
animal = c("A", "B", "C", "D"),
sire   = c("0", "0", "A", "A"),
dam    = c("0", "0", "B", "B"),
stringsAsFactors = FALSE
)
ren <- connectedness::renum_pedigree(ped, verbose = FALSE)
out <- connectedness::build_Ainv(ren)
expect_type(out, "list")
expect_true(all(c("Ainv", "F") %in% names(out)))
expect_s4_class(out$Ainv, "dgCMatrix")
expect_equal(nrow(out$Ainv), nrow(ren))
expect_equal(ncol(out$Ainv), nrow(ren))
expect_length(out$F, nrow(ren))
})
devtools::test()
devtools::test()
devtools::load_all()
devtools::test()
library(connectedness)
detach("package:connectedness", unload = TRUE)
remove.packages("connectedness")
devtools::load_all()
devtools::test()
devtools::load_all()
devtools::test()
build_Ainv()
build_Ainv
sessionInfo()
if ("package:connectedness" %in% search()) {
detach("package:connectedness", unload = TRUE, character.only = TRUE)
}
pkgbuild::clean_dll()
devtools::load_all(recompile = TRUE, reset = TRUE)
is.loaded("_connectedness_build_Ainv_sparse_RA")
is.loaded("_connectedness_compute_Ginv")
is.loaded("_connectedness_cd_contrast_mu_mme_sparse")
pkgbuild::clean_dll()
pkgbuild::compile_dll()
devtools::load_all(reset = TRUE, recompile = FALSE)
dll <- getLoadedDLLs()[["connectedness"]]
names(getDLLRegisteredRoutines(dll)[[".Call"]])
pkgbuild::clean_dll()
pkgbuild::compile_dll()
devtools::load_all(reset = TRUE, recompile = FALSE)
dll <- getLoadedDLLs()[["connectedness"]]
dll
